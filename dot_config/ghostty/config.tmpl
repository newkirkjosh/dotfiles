# Ghostty config — shared with macOS work setup where possible.
# Full reference: https://ghostty.org/docs/config

# ─── Appearance ──────────────────────────────────────────────────────
theme = TokyoNight
font-family = "JetBrainsMono Nerd Font"
font-size = 14
background-opacity = 0.95

# ─── Window ──────────────────────────────────────────────────────────
window-decoration = true
window-padding-x = 10
window-padding-y = 10
confirm-close-surface = false

# ─── Shell integration ───────────────────────────────────────────────
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# ─── Bazzite: no auto-enter needed ───────────────────────────────────
# Ghostty itself is installed inside the arch-dev container (AUR) and
# exported to the host launcher via distrobox-export. Launching Ghostty
# from KDE already runs it inside arch-dev — re-entering would nest.
# Escape hatch for a host shell: `distrobox-host-exec bash` from inside.

# ─── Keybindings ─────────────────────────────────────────────────────
# Let tmux handle splits/tabs; keep Ghostty out of the way.
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
