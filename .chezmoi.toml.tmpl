{{/* chezmoi init template — prompts on first `chezmoi init` */}}

{{- $name := promptStringOnce . "name" "Full name (for git)" -}}
{{- $email := promptStringOnce . "email" "Email (for git)" -}}
{{- $signingkey := promptStringOnce . "signingkey" "SSH public key for commit signing (leave blank to skip)" "" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    signingkey = {{ $signingkey | quote }}

[edit]
    command = "nvim"

[diff]
    pager = "delta"
