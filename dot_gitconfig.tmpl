{{/* ~/.gitconfig — templated from chezmoi prompts. No secrets; signingkey is a public key. */}}

[user]
    name = {{ .name | quote }}
    email = {{ .email | quote }}
{{- if .signingkey }}
    signingkey = {{ .signingkey | quote }}
{{- end }}

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[core]
    autocrlf = input
    editor = nvim

[color]
    ui = auto

[rerere]
    enabled = true

[diff]
    colorMoved = default

{{- if .signingkey }}

[gpg]
    format = ssh

[gpg "ssh"]
    # Bazzite (immutable): /usr/lib/opt/1Password/op-ssh-sign
    # Arch (pacman):       /opt/1Password/op-ssh-sign
    program = "{{ if eq .chezmoi.osRelease.id "bazzite" }}/usr/lib/opt/1Password/op-ssh-sign{{ else }}/opt/1Password/op-ssh-sign{{ end }}"
    allowedSignersFile = "~/.config/git/allowed_signers"

[commit]
    gpgsign = true

[tag]
    gpgsign = true
{{- end }}

{{ if ne .chezmoi.osRelease.id "bazzite" -}}
{{/* On Bazzite, /usr/bin is read-only (ostree) and gh lives under brew.
     Use SSH remotes (git@github.com:...) so pushes go through the 1Password
     SSH agent. The HTTPS credential helper here would only resolve on Arch. */}}
[credential "https://github.com"]
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = !/usr/bin/gh auth git-credential
{{- end }}

[alias]
    st = status -sb
    co = checkout
    cob = checkout -b
    br = branch
    ci = commit
    cm = commit -m
    amend = commit --amend --no-edit
    unstage = reset HEAD --
    last = log -1 HEAD
    df = diff
    dfs = diff --staged
    lg = log --oneline --decorate --graph
    lga = log --oneline --decorate --graph --all
    sync = !git fetch --all --prune && git pull --rebase
    wip = !git add -A && git commit -m 'WIP'
