{{/* ~/.gitconfig — templated from chezmoi prompts. No secrets; signingkey is a public key. */}}

[user]
    name = {{ .name | quote }}
    email = {{ .email | quote }}
{{- if .signingkey }}
    signingkey = {{ .signingkey | quote }}
{{- end }}

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[core]
    autocrlf = input
    editor = nvim

[color]
    ui = auto

[rerere]
    enabled = true

[diff]
    colorMoved = default

{{- if .signingkey }}

[gpg]
    format = ssh

[gpg "ssh"]
    # Path differs per distro — verify with: pacman -Ql 1password | grep op-ssh-sign
    program = "/opt/1Password/op-ssh-sign"

[commit]
    gpgsign = true
{{- end }}

[credential "https://github.com"]
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = !/usr/bin/gh auth git-credential

[alias]
    st = status -sb
    co = checkout
    cob = checkout -b
    br = branch
    ci = commit
    cm = commit -m
    amend = commit --amend --no-edit
    unstage = reset HEAD --
    last = log -1 HEAD
    df = diff
    dfs = diff --staged
    lg = log --oneline --decorate --graph
    lga = log --oneline --decorate --graph --all
    sync = !git fetch --all --prune && git pull --rebase
    wip = !git add -A && git commit -m 'WIP'
