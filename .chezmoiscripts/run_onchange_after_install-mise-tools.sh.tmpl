#!/usr/bin/env bash
# Installs language runtimes via mise.
# - Arch: installs on the host.
# - Bazzite: installs inside the arch-dev distrobox (where dev work lives).

set -euo pipefail

{{ if eq .chezmoi.osRelease.id "bazzite" "fedora" -}}

CONTAINER="{{ .bazzite.distrobox.name }}"

if ! command -v distrobox >/dev/null 2>&1; then
    echo "⚠ distrobox not found — skipping mise setup"
    exit 0
fi

if ! distrobox list | awk '{print $3}' | grep -qx "$CONTAINER"; then
    echo "⚠ distrobox '$CONTAINER' not found — run setup-distrobox first"
    exit 0
fi

if ! distrobox enter "$CONTAINER" -- command -v mise >/dev/null 2>&1; then
    echo "→ [$CONTAINER] installing mise"
    distrobox enter "$CONTAINER" -- bash -c 'curl -fsSL https://mise.run | sh'
fi

# mise refuses to read a pre-existing ~/.config/mise/config.toml unless the
# user has explicitly trusted it. `mise use -g` reads it.
#
# Bazzite quirk: $HOME inside the distrobox is /home/$USER, but mise reports
# the config path as /var/home/$USER/.config/mise/config.toml — the host's
# canonical form, leaking through despite the container having no such path.
# `mise trust` resolves to the wrong prefix (/home/$USER), so its registered
# trust never matches the lookup. MISE_TRUSTED_CONFIG_PATHS sidesteps the
# whole dance by trusting both prefixes declaratively.
TRUSTED_PREFIXES="$HOME/.config:/var/home/$USER/.config"

{{ range .mise }}
distrobox enter "$CONTAINER" -- env "MISE_TRUSTED_CONFIG_PATHS=$TRUSTED_PREFIXES" mise use -g {{ . | quote }}
{{ end }}

{{ else -}}

if ! command -v mise >/dev/null 2>&1; then
    echo "⚠ mise not installed — skipping. Run install.sh first."
    exit 0
fi

# See Bazzite quirk comment above; on Arch host the prefix split is harmless.
export MISE_TRUSTED_CONFIG_PATHS="$HOME/.config:/var/home/$USER/.config"

{{ range .mise }}
mise use -g {{ . | quote }}
{{ end }}

{{ end -}}
