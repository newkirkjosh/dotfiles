#!/usr/bin/env bash
# Installs AUR packages via yay.
# Reruns when this script or packages.yaml changes.

set -euo pipefail

{{ if eq .chezmoi.osRelease.id "arch" "cachyos" "endeavouros" "manjaro" -}}

if ! command -v yay >/dev/null 2>&1; then
    echo "⚠ yay not installed — skipping AUR packages. Run install.sh first."
    exit 0
fi

PACKAGES=(
{{- range .arch.aur }}
    {{ . | quote }}
{{- end }}
)

echo "→ Installing ${#PACKAGES[@]} AUR packages"
yay -S --needed --noconfirm "${PACKAGES[@]}"

{{ end -}}
